#: includes/csv2wp-file-handling.php:5 includes/csv2wp-help-tabs.php:27
#: includes/csv2wp-help-tabs.php:47
msgid "Handle a CSV file"
msgstr "Verwerk een CSV bestand"

#: includes/csv2wp-file-handling.php:8
msgid ""
"Select a file, select where to import it, whether the file has a header row "
"and if you want to limit the amount of lines."
msgstr ""
"Selecteer een bestand, kies waar het geïmporteerd moet worden, of het "
"bestand een 'header regel' heeft en of je het aantal regels wilt beperken."

#: includes/csv2wp-file-handling.php:19 includes/csv2wp-preview-form.php:8
msgid "File name"
msgstr "Bestandsnaam"

#: includes/csv2wp-file-handling.php:20
msgid "Import in"
msgstr "Importeer in"

#: includes/csv2wp-file-handling.php:21 includes/csv2wp-preview-form.php:9
msgid "Delimiter"
msgstr "Scheidingsteken"

#: includes/csv2wp-file-handling.php:22
msgid "Table"
msgstr "Tabel"

#: includes/csv2wp-file-handling.php:22
msgid "Meta key"
msgstr "Meta key"

#: includes/csv2wp-file-handling.php:23 includes/csv2wp-preview-form.php:11
msgid "Max. lines"
msgstr "Max. regels"

#: includes/csv2wp-file-handling.php:32 includes/csv2wp-preview-form.php:21
msgid "Select a file"
msgstr "Selecteer een bestand"

